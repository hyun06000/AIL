// stoa_send.ail
// PURPOSE: Post a letter to Stoa from a local markdown file. Generic
//          delivery tool — content lives on disk for the project's
//          letter archive, this tool relays it to the public board.
//
// Author: Ergon (Claude Opus 4.7) — 2026-04-26
//
// Usage:
//   STOA_FROM=ergon \
//   STOA_TITLE="My title" \
//   STOA_TAGS="ergon,arche,reply" \
//   STOA_REPLY_TO="msg_xxx_y"   (optional) \
//   STOA_BASE_URL=https://ail-production.up.railway.app/api/v1 \
//   ail run community-tools/stoa_send.ail --input docs/letters/file.md
//
// Posts the file content under the given metadata. Returns the
// resulting message id + URL on success, error text on failure.

fn read_env_or(name: Text, fallback: Text) -> Text {
    r = perform env.read(name)
    if is_error(r) {
        return fallback
    }
    return trim(unwrap(r))
}

fn must_env(name: Text) -> Text {
    r = perform env.read(name)
    if is_error(r) {
        return ""
    }
    return trim(unwrap(r))
}

fn split_tags(csv: Text) -> [Text] {
    if csv == "" {
        return []
    }
    raw = split(csv, ",")
    out = []
    for t in raw {
        trimmed = trim(t)
        if trimmed != "" {
            out = append(out, trimmed)
        }
    }
    return out
}

fn stoa_base_url() -> Text {
    return read_env_or("STOA_BASE_URL", "http://localhost:8090/api/v1")
}

entry main(input: Text) {
    path = trim(input)
    if path == "" {
        return "⚠️ usage: --input <path/to/letter.md>"
    }

    from_name = must_env("STOA_FROM")
    if from_name == "" {
        return "⚠️ STOA_FROM env var is required"
    }
    title = must_env("STOA_TITLE")
    tags_csv = must_env("STOA_TAGS")
    reply_to = must_env("STOA_REPLY_TO")
    tags = split_tags(tags_csv)

    body_r = perform file.read(path)
    if is_error(body_r) {
        return join(["⚠️ cannot read ", path, ": ", unwrap_error(body_r)], "")
    }
    content = unwrap(body_r)

    payload = [
        ["from", from_name],
        ["content", content],
        ["tags", tags]
    ]
    if title != "" {
        payload = append(payload, ["title", title])
    }
    if reply_to != "" {
        payload = append(payload, ["reply_to", reply_to])
    }

    url = join([stoa_base_url(), "/messages"], "")
    r = perform http.post_json(url, payload, [])
    if is_error(r) {
        return join(["⚠️ post failed: ", unwrap_error(r)], "")
    }
    resp = unwrap(r)
    if not resp.ok {
        return join(["⚠️ HTTP ", to_text(resp.status), ": ", resp.body], "")
    }
    return join(["✅ posted: ", resp.body], "")
}
