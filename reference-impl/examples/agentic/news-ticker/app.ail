// entry returns structured data. Presentation lives in view.html;
// the client fetches POST / to get this record and renders it.

entry main(input: Text) {
    // Arm the recurring tick (latest call wins; idempotent).
    a = perform schedule.every(10)
    armed = is_ok(a)

    // Read / bump the counter.
    prior = perform state.read("tick_count")
    n = 0
    if is_ok(prior) { n = unwrap(prior) }
    n = n + 1
    perform state.write("tick_count", n)

    return {"ticks": n, "armed": armed}
}
